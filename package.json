{
  "name": "webtoon-front",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "playwright test",
    "test:mobile": "playwright test --project='Mobile Chrome'",
    "test:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply webtoon-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply webtoon-db --remote",
    "db:seed:local": "wrangler d1 execute webtoon-db --local --file db/seed.sql",
    "db:seed:remote": "wrangler d1 execute webtoon-db --remote --file db/seed.sql",
    "db:push": "drizzle-kit push",
    "db:push:remote": "DATABASE_URL=remote drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:studio:remote": "DATABASE_URL=remote drizzle-kit studio",
    "db:console:local": "wrangler d1 execute webtoon-db --local --config wrangler.dev.jsonc --command",
    "db:console:remote": "wrangler d1 execute webtoon-db --remote --config wrangler.jsonc --command",
    "healthcheck": "node scripts/healthcheck.js",
    "healthcheck:local": "./scripts/healthcheck-local.sh",
    "healthcheck:api": "./scripts/healthcheck-api.sh",
    "healthcheck:production": "./scripts/healthcheck-production.sh"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@solidgate/react-sdk": "^1.24.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.16",
    "better-auth": "^1.4.10",
    "better-auth-cloudflare": "^0.2.9",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.26",
    "hono": "^4.11.3",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.562.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4.2.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "vaul": "^1.1.2",
    "xgplayer": "^3.0.23",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.20.1",
    "@cloudflare/workers-types": "^4.20260111.0",
    "@eslint/js": "^9.39.1",
    "@libsql/client": "^0.17.0",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/eslint-plugin-query": "^5.91.2",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@tanstack/react-router-devtools": "^1.144.0",
    "@tanstack/router-plugin": "^1.145.2",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-dom": "^2.7.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-hooks-extra": "^2.7.2",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-react-x": "^2.7.2",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "npm:rolldown-vite@7.2.5",
    "wrangler": "^4.54.0"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  }
}
