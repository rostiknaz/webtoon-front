# Cloudflare Account
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# Cloudflare D1 Database
CLOUDFLARE_D1_DATABASE_ID=3eb45b23-733f-4ed1-9990-fbb1a9c82179

# Better Auth
BETTER_AUTH_SECRET=your_random_secret_key_here
BETTER_AUTH_URL=http://localhost:5174

# Solidgate Payment Gateway
SOLIDGATE_MERCHANT_ID=your_merchant_id_here
SOLIDGATE_SECRET_KEY=your_secret_key_here
SOLIDGATE_PUBLIC_KEY=your_public_key_here
SOLIDGATE_WEBHOOK_SECRET=your_webhook_secret_here

# Cloudflare Stream (already in use)
CLOUDFLARE_STREAM_CUSTOMER_CODE=9u10nm8oora2n5zb

# OAuth Providers (optional - configure as needed)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# Email Provider (optional - for email verification)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_password_here
# SMTP_FROM=noreply@example.com
