# ===============================================
# Environment Variables Configuration
# ===============================================
#
# LOCAL DEVELOPMENT:
# Copy this file to .dev.vars for local development
# DO NOT use .env files - Cloudflare Vite plugin prioritizes .dev.vars
#
# PRODUCTION:
# Use `wrangler secret put <KEY>` for sensitive data
# Use wrangler.jsonc "vars" for non-sensitive config
#
# See: https://developers.cloudflare.com/workers/configuration/secrets/
# ===============================================

# ===============================================
# Cloudflare Stream Configuration
# ===============================================
CLOUDFLARE_STREAM_CUSTOMER_CODE=9u10nm8oora2n5zb
CLOUDFLARE_STREAM_FALLBACK_VIDEO_ID=e173ed29029287118d810abce2ea35c5

# ===============================================
# Solidgate Payment Gateway (SECRETS)
# ===============================================
# These are SECRETS - never commit actual values!
# Production: Use `wrangler secret put SOLIDGATE_SECRET_KEY`
SOLIDGATE_MERCHANT_ID=your_merchant_id_here
SOLIDGATE_SECRET_KEY=your_secret_key_here
SOLIDGATE_PUBLIC_KEY=your_public_key_here
SOLIDGATE_WEBHOOK_SECRET=your_webhook_secret_here

# ===============================================
# Better Auth Configuration (SECRETS)
# ===============================================
# Generate random secret: openssl rand -base64 32
# Production: Use `wrangler secret put BETTER_AUTH_SECRET`
BETTER_AUTH_SECRET=your_random_secret_key_here
BETTER_AUTH_URL=http://localhost:5173
VITE_BETTER_AUTH_URL=http://localhost:5173

# ===============================================
# R2 CDN Configuration
# ===============================================
# Public R2 bucket URL for HLS video streaming
VITE_R2_CDN_URL=https://pub-e8eb9b2155904feeb0e7c5e0712a87e2.r2.dev

# ===============================================
# Cloudflare Account (for CI/CD only)
# ===============================================
# Only needed for automated deployments
# CLOUDFLARE_ACCOUNT_ID=your_account_id_here
# CLOUDFLARE_API_TOKEN=your_api_token_here

# ===============================================
# OAuth Providers (Optional)
# ===============================================
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# ===============================================
# Email Provider (Optional)
# ===============================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_password_here
# SMTP_FROM=noreply@example.com

# ===============================================
# Production Deployment Instructions
# ===============================================
#
# 1. Set secrets (one-time setup):
#    wrangler secret put SOLIDGATE_SECRET_KEY
#    wrangler secret put SOLIDGATE_WEBHOOK_SECRET
#    wrangler secret put BETTER_AUTH_SECRET
#
# 2. Deploy to production:
#    npm run build
#    wrangler deploy
#
# 3. Deploy to staging:
#    CLOUDFLARE_ENV=staging wrangler deploy
#
# 4. View production secrets (names only):
#    wrangler secret list
#
# Note: You cannot view secret values after setting them.
# This is by design for security.
# ===============================================
